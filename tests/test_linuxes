#!/usr/bin/env bash

shopt -s nullglob

function error() {
	echo "$@" >&2
	exit 1
}

function cleanup() {
	printf "\x1b[0m\n"
	docker system prune -f >/dev/null 2>&1
}

function test_linux() {
	local dockerfile="$1"
	local distro=${dockerfile##*.}
	local image_name="dev-sercon-${distro}"
	(
		printf "\x1b[33m================================================\x1b[0m\n"
		printf "\x1b[33mBuilding and running docker image for ${distro^^}\x1b[0m\n"
		printf "\x1b[33m================================================\x1b[0m\n"

		printf "\x1b[2m"
		docker build --progress=plain -t "$image_name" -f "$dockerfile" .
		printf "\x1b[0m"

		for SCENARIO in "${SCENARIOS[@]}"; do
			cat "${SCENARIO}" \
				| docker run --rm  -i --privileged -v ~/sercon:/sercon "$image_name" bash -c "make run"
		done
	)
	local status=$?
	return $status
}


# build scenarios array from command line arguments
SCENARIOS=()
while [ -n "$1" ]; do
	SCENARIOS+=( "$(realpath "$1")" )
	shift
done
[ ${#SCENARIOS[@]} -gt 0 ] || error "No scenarios provided. Usage: $0 <scenario1> <scenario2> ..."

cd $(dirname "$0")

# Find the root of the repository by looking for a Makefile
while [ ! -f "Makefile" ]; do
	cd ..
	[ "$PWD" = "/" ] && error "Could not find the root of the repository (Makefile not found)"
done

# Check if docker service is running
docker info >/dev/null 2>&1  || error "Docker daemon is not available"

trap cleanup EXIT

declare -A results || error "Bash 4+ is required to run this script"
results=()

# for each Dockerfile found under the docker/ directory,
# build and run the image, and store the result
for dockerfile in docker/Dockerfile.*; do
	distro=${dockerfile##*.}
	if test_linux "$dockerfile"; then
		results["$distro"]=ok
	else
		results["$distro"]=failed
	fi
done

# summary of results
failures=0
total=0
printf "\n"
printf "====== Results ======\n"
printf "\n"
for linux in "${!results[@]}"; do
	total=$((total + 1))
	printf "%d) %s: " "$total" "${linux^}"
	if [ "${results[$linux]}" = "ok" ]; then
		printf "✅\n"
	else
		printf "❌\n"
		failures=$((failures + 1))
	fi
done
printf "\n"
printf "Total: %d, Failures: %d\n" "$total" "$failures"
# printf "=====================\n"

[[ $failures == 0 ]] || exit 1
