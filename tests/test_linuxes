#!/usr/bin/env bash

function cleanup {
		docker system prune -f >/dev/null 2>&1
}

function test_linux() {
		local dir="$1"
		local linux=$(basename "$dir")
		(
			cd "$dir" || exit 1

			printf "================================================\n"
			printf "Building and running docker image for $(echo $linux | tr '[:lower:]' '[:upper:]')\n"
			printf "================================================\n"

			local image_name="dev-sercon-${linux}"

			docker build --progress=plain -t "$image_name" .
			docker run --rm -it -v ~/sercon:/sercon "$image_name" \
				bash -c "echo help | make run -- -H"
		)
		local status=$?
		return $status
}

cd $(dirname "$0")/../docker

# Check if docker is installed
docker info >/dev/null 2>&1 || exit 1

trap cleanup EXIT

declare -A results
results=()
shopt -s nullglob

for d in * ; do
	[ -d "$d" ] || continue
	if test_linux "$d"; then
		results["$d"]=ok
	else
		results["$d"]=failed
	fi
done

# summary of results
printf "\n--- Test Results ---\n"
total=0
successes=0
failures=0
for linux in "${!results[@]}"; do
		printf "%s: " "${linux^^}"
		if [ "${results[$linux]}" = "ok" ]; then
			printf "✅\n"
			successes=$((successes + 1))
		else
			printf "❌\n"
			failures=$((failures + 1))
		fi
		total=$((total + 1))
done

# printf "\nTotal: %d, Successes: %d, Failures: %d\n" "$total" "$successes" "$failures"

[[ $failures -eq 0 ]] || exit 1
