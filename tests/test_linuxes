#!/usr/bin/env bash

function cleanup {
	printf "\x1b[0m"
	docker system prune -f >/dev/null 2>&1
}

function test_linux() {
	local dir="$1"
	local linux=$(basename "$dir")
	local image_name="test-sercon-${linux}"
	(
		cd "$dir" || exit 1

		printf "\x1b[33m================================================\x1b[0m\n"
		printf "\x1b[33mBuilding and running docker image for ${linux^^}\x1b[0m\n"
		printf "\x1b[33m================================================\x1b[0m\n"

		printf "\x1b[2m"
		docker build --progress=plain -t "$image_name" .
		printf "\x1b[0m"

		docker run --rm -it -v ~/sercon:/sercon "$image_name" \
			bash -c "echo ports | make run -- -H"
	)
	local status=$?
	return $status
}

cd $(dirname "$0")/..

# Check if docker service is running
docker info >/dev/null 2>&1 || exit 1

trap cleanup EXIT

declare -A results
results=()
shopt -s nullglob

# for each Dockerfile found under the docker/ directory,
# build and run the image, and store the result
for dockerfile in $(find docker/. -name Dockerfile) ; do
	dir=$(dirname "$dockerfile")
	[ -d "$dir" ] || continue
	linux=$(basename "$dir")
	if test_linux "$dir"; then
		results["$linux"]=ok
	else
		results["$linux"]=failed
	fi
done

# summary of results
printf "\n--- Test Results ---\n"
total=0
successes=0
failures=0
for linux in "${!results[@]}"; do
	printf "%s: " "${linux^}"
	if [ "${results[$linux]}" = "ok" ]; then
		printf "✅\n"
		successes=$((successes + 1))
	else
		printf "❌\n"
		failures=$((failures + 1))
	fi
	total=$((total + 1))
done

# printf "\nTotal: %d, Successes: %d, Failures: %d\n" "$total" "$successes" "$failures"

[[ $failures -eq 0 ]] || exit 1
